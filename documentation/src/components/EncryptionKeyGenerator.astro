<div class="api-key-input">
  <input type="text" id="api-key" onclick="this.focus();this.select()" readonly />
  <button type="button" id="regenerate-api-key" aria-label="Regenerate API key">Regenerate</button>
  <button type="button" id="copy-api-key" aria-label="Copy API key" class="primary">Copy</button>
</div>

<script>
  const abc = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/';
  const bin = (n: number) => n.toString(2).padStart(8, '0');

  const bytesArrToBase64 = (arr: Uint8Array) => {
    let result = '';
    for (let i = 0; i <= (arr.length - 1) / 3; i++) {
      const c1 = i * 3 + 1 >= arr.length;
      const c2 = i * 3 + 2 >= arr.length;
      const chunk = `${bin(arr[3 * i])}${bin(c1 ? 0 : arr[3 * i + 1])}${bin(c2 ? 0 : arr[3 * i + 2])}`;
      const values = (chunk.match(/.{1,6}/g) || []).map((x, j) => {
        if (j === 3 && c2) return '=';
        if (j === 2 && c1) return '=';
        return abc[Number(`0b${x}`)];
      });
      result += values.join('');
    }
    return result;
  };

  const updateApiKey = () => {
    const array = new Uint8Array(32);
    window.crypto.getRandomValues(array);
    const input = document.getElementById('api-key') as HTMLInputElement | null;
    if (input) input.value = bytesArrToBase64(array);
  };

  updateApiKey();
  document.getElementById('regenerate-api-key')?.addEventListener('click', updateApiKey);

  document.getElementById('copy-api-key')?.addEventListener('click', async () => {
    const input = document.getElementById('api-key') as HTMLInputElement | null;
    const copyButton = document.getElementById('copy-api-key');
    if (!input || !copyButton) return;
    input.select();
    input.setSelectionRange(0, 99999);
    await navigator.clipboard.writeText(input.value);
    copyButton.textContent = 'Copied!';
    copyButton.focus();
    setTimeout(() => {
      copyButton.textContent = 'Copy';
    }, 1200);
  });
</script>

<style>
  .api-key-input {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .api-key-input input[type='text'] {
    width: 32rem;
    max-width: 100%;
  }

  .api-key-input button {
    border: 1px solid var(--sl-color-accent-high);
    background: transparent;
    color: var(--sl-color-text);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
    font-weight: 600;
    cursor: pointer;
  }

  .api-key-input button.primary {
    background: var(--sl-color-accent);
    color: var(--sl-color-white);
    border-color: var(--sl-color-accent);
  }
</style>

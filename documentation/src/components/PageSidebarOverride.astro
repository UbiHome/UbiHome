---
import Default from "@astrojs/starlight/components/PageSidebar.astro";
import { PageGraph } from "starlight-site-graph/components";
import config from "virtual:starlight-site-graph/config";
import astroConfig from "virtual:starlight-site-graph/astro-config";

interface SitemapEntry {
	title?: string;
	backlinks?: string[];
}

const ensureTrailingSlash = (value: string, add: boolean): string => {
	if (!add) {
		return value.endsWith("/") ? value.slice(0, -1) : value;
	}
	return value.endsWith("/") ? value : `${value}/`;
};

const stripSlashes = (value: string, onlyStripPrefix?: boolean): string => {
	let normalized = value;
	if (normalized.startsWith("/")) {
		normalized = normalized.slice(1);
	}
	if (!onlyStripPrefix && normalized.endsWith("/")) {
		normalized = normalized.slice(0, -1);
	}
	return normalized;
};

const isExampleBacklink = (link: string): boolean => {
	const normalized = stripSlashes(link);
	return (
		normalized === "examples" ||
		normalized.startsWith("examples/") ||
		normalized.includes("/examples/")
	);
};

const isExamplesOverviewBacklink = (link: string): boolean => stripSlashes(link) === "examples";

const isTagBacklink = (link: string): boolean => {
	const normalized = stripSlashes(link);
	return (
		normalized === "tags" ||
		normalized.startsWith("tags/") ||
		normalized.includes("/tags/")
	);
};

const trailingSlashes = astroConfig.trailingSlashes !== "never";
const slugWithBase = ensureTrailingSlash(
	stripSlashes(Astro.url.pathname.replaceAll("\\", "/")),
	trailingSlashes,
);

const sitemap = (config.sitemapConfig?.sitemap ?? {}) as Record<string, SitemapEntry>;
const backlinks = [...(sitemap[slugWithBase]?.backlinks ?? [])]
	.filter((link) => !isTagBacklink(link))
	.filter((link) => !isExamplesOverviewBacklink(link))
	.sort((a, b) => (sitemap[a]?.title ?? a).localeCompare(sitemap[b]?.title ?? b));

const exampleBacklinks = backlinks.filter(isExampleBacklink);
const relatedBacklinks = backlinks.filter((link) => !isExampleBacklink(link));
const showBacklinksPanel = backlinks.length > 0;
---

<PageGraph class="right-sidebar-panel slsg-graph-panel">
	<h2 slot="title">{Astro.locals.t("starlight-site-graph.graph")}</h2>
</PageGraph>

<Default>
	<slot />
</Default>

{showBacklinksPanel && (
	<div class="right-sidebar-panel slsg-backlinks-panel" data-slug={slugWithBase}>
		<h2>{Astro.locals.t("starlight-site-graph.backlinks")}</h2>

		{exampleBacklinks.length > 0 && (
			<section class="slsg-backlinks-section" data-group="examples">
				<h3>Examples</h3>
				<ul class="slsg-backlinks" style="--depth: 0;">
					{exampleBacklinks.map((link) => (
						<li style="--depth: 0;">
							<a href={`/${stripSlashes(link, true)}`} style="--depth: 0;" target="_self" class="slsg-backlink">
								<span style="--depth: 0;">{sitemap[link]?.title ?? link}</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		)}

		{relatedBacklinks.length > 0 && (
			<section class="slsg-backlinks-section" data-group="related">
				<h3>Related</h3>
				<ul class="slsg-backlinks" style="--depth: 0;">
					{relatedBacklinks.map((link) => (
						<li style="--depth: 0;">
							<a href={`/${stripSlashes(link, true)}`} style="--depth: 0;" target="_self" class="slsg-backlink">
								<span style="--depth: 0;">{sitemap[link]?.title ?? link}</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		)}
	</div>
)}

<script>
	const cleanLink = (link) => String(link || "").replace(/^\/+/, "");
	const trimSlashes = (value) => String(value || "").replace(/^\/+|\/+$/g, "");

	const isExampleBacklink = (link) => {
		const normalized = trimSlashes(link);
		return (
			normalized === "examples" ||
			normalized.startsWith("examples/") ||
			normalized.includes("/examples/")
		);
	};

	const isExamplesOverviewBacklink = (link) => trimSlashes(link) === "examples";

	const isTagBacklink = (link) => {
		const normalized = trimSlashes(link);
		return (
			normalized === "tags" ||
			normalized.startsWith("tags/") ||
			normalized.includes("/tags/")
		);
	};

	const renderGroup = (panel, title, links, sitemap, dataGroup) => {
		let section = panel.querySelector(`.slsg-backlinks-section[data-group="${dataGroup}"]`);
		if (links.length === 0) {
			section?.remove();
			return;
		}

		if (!section) {
			section = document.createElement("section");
			section.className = "slsg-backlinks-section";
			section.setAttribute("data-group", dataGroup);

			const h3 = document.createElement("h3");
			h3.textContent = title;
			section.appendChild(h3);

			const list = document.createElement("ul");
			list.className = "slsg-backlinks";
			list.style.setProperty("--depth", "0");
			section.appendChild(list);

			panel.appendChild(section);
		}

		const list = section.querySelector(".slsg-backlinks");
		if (!list) return;
		list.innerHTML = "";

		for (const link of links) {
			const li = document.createElement("li");
			li.style.setProperty("--depth", "0");

			const a = document.createElement("a");
			a.href = `/${cleanLink(link)}`;
			a.style.setProperty("--depth", "0");
			a.target = "_self";
			a.className = "slsg-backlink";

			const span = document.createElement("span");
			span.style.setProperty("--depth", "0");
			span.textContent = String(sitemap[link]?.title ?? link);

			a.appendChild(span);
			li.appendChild(a);
			list.appendChild(li);
		}
	};

	window.addEventListener("DOMContentLoaded", () => {
		if (!import.meta.env.PROD) return;

		let baseUrl = import.meta.env.BASE_URL;
		if (!baseUrl.endsWith("/")) {
			baseUrl += "/";
		}

		const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));
		onIdle(async () => {
			const panel = document.querySelector(".slsg-backlinks-panel[data-slug]");
			if (!panel) return;

			const sitemap = await (await fetch(`${baseUrl}sitegraph/sitemap.json`)).json();
			const slug = panel.getAttribute("data-slug") ?? "";
			const entry = sitemap[slug];
			const allBacklinks = Array.isArray(entry?.backlinks)
				? entry.backlinks
						.filter((link) => !isTagBacklink(link))
						.filter((link) => !isExamplesOverviewBacklink(link))
				: [];
			if (allBacklinks.length === 0) {
				panel.remove();
				return;
			}

			allBacklinks.sort((a, b) =>
				String(sitemap[a]?.title ?? a).localeCompare(String(sitemap[b]?.title ?? b)),
			);

			const examples = allBacklinks.filter(isExampleBacklink);
			const related = allBacklinks.filter((link) => !isExampleBacklink(link));

			renderGroup(panel, "Examples", examples, sitemap, "examples");
			renderGroup(panel, "Related", related, sitemap, "related");
		});
	});
</script>

<style>
	.slsg-backlinks-section + .slsg-backlinks-section {
		margin-top: 0.75rem;
	}

	.slsg-backlinks-section h3 {
		font-size: var(--sl-text-xs);
		font-weight: 600;
		color: var(--sl-color-gray-2);
		margin: 0.25rem 0;
	}
</style>
